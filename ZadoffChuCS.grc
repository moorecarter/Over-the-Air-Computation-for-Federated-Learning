- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, root=1, length=139, threshold_ratio=0.75):\n       \
      \ gr.sync_block.__init__(\n            self,\n            name='ZC Correlator\
      \ & Data Averager',\n            in_sig=[np.complex64],\n            out_sig=[np.complex64,\
      \ np.complex64] # Port 0: ZC State, Port 1: Data Average\n        )\n      \
      \  self.root = root\n        self.length = length\n        self.threshold_ratio\
      \ = threshold_ratio\n        \n        # Latched memories\n        self.last_h\
      \ = 1.0 + 0.0j\n        self.last_data_avg = 1.0 + 0.0j\n        \n        #\
      \ State machine for the data catcher\n        self.is_collecting = False\n \
      \       self.samples_collected = 0\n        self.current_sum = 0.0 + 0.0j\n\
      \        \n        self.seq = self._generate_zc()\n        self.set_history(self.length)\n\
      \n    def _generate_zc(self):\n        n = np.arange(self.length)\n        if\
      \ self.length % 2 == 0:\n            seq = np.exp(-1j * np.pi * self.root *\
      \ (n ** 2) / self.length)\n        else:\n            seq = np.exp(-1j * np.pi\
      \ * self.root * n * (n + 1) / self.length)\n        return seq.astype(np.complex64)\n\
      \n    def work(self, input_items, output_items):\n        in_sig = input_items[0]\n\
      \        out_zc_state = output_items[0]\n        out_data_avg = output_items[1]\n\
      \        \n        # 1. Sliding Correlation for the Preamble\n        corr =\
      \ np.correlate(in_sig, self.seq, mode='valid')\n        chan_est_list = corr\
      \ / self.length\n        mags = np.abs(chan_est_list)\n\n        for i in range(len(out_zc_state)):\n\
      \            # --- ZC PREAMBLE LOGIC (Port 0) ---\n            if mags[i] >=\
      \ self.threshold_ratio:\n                # Instant update of channel state from\
      \ ZC\n                self.last_h = chan_est_list[i]\n                \n   \
      \             # Trigger the data catcher to start fresh\n                self.is_collecting\
      \ = True\n                self.samples_collected = 0\n                self.current_sum\
      \ = 0.0 + 0.0j\n            \n            # --- DATA CATCHER LOGIC (Port 1)\
      \ ---\n            if self.is_collecting:\n                # The data follows\
      \ the ZC. \n                # in_sig[i + length - 1] is the sample exactly after\
      \ the ZC correlation window\n                self.current_sum += in_sig[i +\
      \ self.length-1]\n                self.samples_collected += 1\n            \
      \    \n                if self.samples_collected >= self.length:\n         \
      \           # Finalize the average for this frame\n                    self.last_data_avg\
      \ = self.current_sum / self.length\n                    self.is_collecting =\
      \ False\n            \n            # Write out the latched values to their respective\
      \ ports\n            out_zc_state[i] = self.last_h\n            out_data_avg[i]\
      \ = self.last_data_avg\n            \n        return len(out_zc_state)\n"
    affinity: ''
    alias: ''
    comment: ''
    length: '255'
    maxoutbuf: '0'
    minoutbuf: '0'
    root: '1'
    threshold_ratio: '0.6'
  states:
    _io_cache: ('ZC Correlator & Data Averager', 'blk', [('root', '1'), ('length',
      '139'), ('threshold_ratio', '0.75')], [('0', 'complex', 1)], [('0', 'complex',
      1), ('1', 'complex', 1)], '', ['length', 'root', 'threshold_ratio'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1616, 1504.0]
