- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Zadoff-Chu Sequence Generator\n    Generates a continuous,\
      \ repeating Zadoff-Chu sequence.\n    \"\"\"\n\n    def __init__(self, root=1,\
      \ length=139):\n        # Initialize the sync block with no inputs and one complex\
      \ output\n        gr.sync_block.__init__(\n            self,\n            name='Zadoff-Chu\
      \ Source',\n            in_sig=[],\n            out_sig=[np.complex64]\n   \
      \     )\n        \n        # Store parameters\n        self.root = root\n  \
      \      self.length = length\n        \n        # Internal state\n        self.idx\
      \ = 0\n        self.seq = self._generate_zc()\n\n    def _generate_zc(self):\n\
      \        \"\"\"Calculates the ZC sequence based on current root and length.\"\
      \"\"\n        n = np.arange(self.length)\n        if self.length % 2 == 0:\n\
      \            # Even length formula\n            seq = np.exp(-1j * np.pi * self.root\
      \ * (n ** 2) / self.length)\n        else:\n            # Odd length formula\n\
      \            seq = np.exp(-1j * np.pi * self.root * n * (n + 1) / self.length)\n\
      \        return seq.astype(np.complex64)\n\n    def set_root(self, root):\n\
      \        \"\"\"Callback for the root variable.\"\"\"\n        self.root = root\n\
      \        self.seq = self._generate_zc()\n        self.idx = 0 # Reset index\
      \ to avoid out-of-bounds on length change\n\n    def set_length(self, length):\n\
      \        \"\"\"Callback for the length variable.\"\"\"\n        if length <\
      \ 1:\n            length = 1\n        self.length = int(length)\n        self.seq\
      \ = self._generate_zc()\n        self.idx = 0 # Reset index to avoid out-of-bounds\n\
      \n    def work(self, input_items, output_items):\n        out = output_items[0]\n\
      \        n_output = len(out)\n        \n        # Fast array assignment to handle\
      \ the repeating sequence\n        remaining = n_output\n        out_idx = 0\n\
      \        \n        while remaining > 0:\n            # Calculate how much of\
      \ the sequence we can write in this loop\n            chunk_size = min(remaining,\
      \ self.length - self.idx)\n            \n            # Write the chunk to the\
      \ output buffer\n            out[out_idx:out_idx + chunk_size] = self.seq[self.idx:self.idx\
      \ + chunk_size]\n            \n            # Update pointers and counters\n\
      \            self.idx = (self.idx + chunk_size) % self.length\n            out_idx\
      \ += chunk_size\n            remaining -= chunk_size\n            \n       \
      \ return n_output\n"
    affinity: ''
    alias: ''
    comment: ''
    length: '255'
    maxoutbuf: '0'
    minoutbuf: '0'
    root: '1'
  states:
    _io_cache: ('Zadoff-Chu Source', 'blk', [('root', '1'), ('length', '139')], [],
      [('0', 'complex', 1)], '\n    Zadoff-Chu Sequence Generator\n    Generates a
      continuous, repeating Zadoff-Chu sequence.\n    ', ['length', 'root'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [456, 1512.0]
    rotation: 0
    state: disabled
- name: epy_block_0_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Zadoff-Chu Sequence Generator\n    Generates a continuous,\
      \ repeating Zadoff-Chu sequence.\n    \"\"\"\n\n    def __init__(self, root=1,\
      \ length=139):\n        # Initialize the sync block with no inputs and one complex\
      \ output\n        gr.sync_block.__init__(\n            self,\n            name='Zadoff-Chu\
      \ Source',\n            in_sig=[],\n            out_sig=[np.complex64]\n   \
      \     )\n        \n        # Store parameters\n        self.root = root\n  \
      \      self.length = length\n        \n        # Internal state\n        self.idx\
      \ = 0\n        self.seq = self._generate_zc()\n\n    def _generate_zc(self):\n\
      \        \"\"\"Calculates the ZC sequence based on current root and length.\"\
      \"\"\n        n = np.arange(self.length)\n        if self.length % 2 == 0:\n\
      \            # Even length formula\n            seq = np.exp(-1j * np.pi * self.root\
      \ * (n ** 2) / self.length)\n        else:\n            # Odd length formula\n\
      \            seq = np.exp(-1j * np.pi * self.root * n * (n + 1) / self.length)\n\
      \        return seq.astype(np.complex64)\n\n    def set_root(self, root):\n\
      \        \"\"\"Callback for the root variable.\"\"\"\n        self.root = root\n\
      \        self.seq = self._generate_zc()\n        self.idx = 0 # Reset index\
      \ to avoid out-of-bounds on length change\n\n    def set_length(self, length):\n\
      \        \"\"\"Callback for the length variable.\"\"\"\n        if length <\
      \ 1:\n            length = 1\n        self.length = int(length)\n        self.seq\
      \ = self._generate_zc()\n        self.idx = 0 # Reset index to avoid out-of-bounds\n\
      \n    def work(self, input_items, output_items):\n        out = output_items[0]\n\
      \        n_output = len(out)\n        \n        # Fast array assignment to handle\
      \ the repeating sequence\n        remaining = n_output\n        out_idx = 0\n\
      \        \n        while remaining > 0:\n            # Calculate how much of\
      \ the sequence we can write in this loop\n            chunk_size = min(remaining,\
      \ self.length - self.idx)\n            \n            # Write the chunk to the\
      \ output buffer\n            out[out_idx:out_idx + chunk_size] = self.seq[self.idx:self.idx\
      \ + chunk_size]\n            \n            # Update pointers and counters\n\
      \            self.idx = (self.idx + chunk_size) % self.length\n            out_idx\
      \ += chunk_size\n            remaining -= chunk_size\n            \n       \
      \ return n_output\n"
    affinity: ''
    alias: ''
    comment: ''
    length: '255'
    maxoutbuf: '0'
    minoutbuf: '0'
    root: '1'
  states:
    _io_cache: ('Zadoff-Chu Source', 'blk', [('root', '1'), ('length', '139')], [],
      [('0', 'complex', 1)], '\n    Zadoff-Chu Sequence Generator\n    Generates a
      continuous, repeating Zadoff-Chu sequence.\n    ', ['length', 'root'])
    bus_sink: false
