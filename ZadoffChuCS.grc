- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Zadoff-Chu Correlator with Latch\n    Holds the last successful\
      \ channel estimate (h) until a new peak is found.\n    Initializes at 1+0j.\n\
      \    \"\"\"\n\n    def __init__(self, root=1, length=139, threshold_ratio=0.75):\n\
      \        gr.sync_block.__init__(\n            self,\n            name='ZC Correlator\
      \ (Latched)',\n            in_sig=[np.complex64],\n            out_sig=[np.complex64]\n\
      \        )\n        \n        self.root = root\n        self.length = length\n\
      \        self.threshold_ratio = threshold_ratio\n        \n        # This is\
      \ our 'memory' variable\n        self.last_h = 1.0 + 0.0j\n        \n      \
      \  self.seq = self._generate_zc()\n        self.set_history(self.length)\n\n\
      \    def _generate_zc(self):\n        n = np.arange(self.length)\n        if\
      \ self.length % 2 == 0:\n            seq = np.exp(-1j * np.pi * self.root *\
      \ (n ** 2) / self.length)\n        else:\n            seq = np.exp(-1j * np.pi\
      \ * self.root * n * (n + 1) / self.length)\n        return seq.astype(np.complex64)\n\
      \n    def set_root(self, root):\n        self.root = root\n        self.seq\
      \ = self._generate_zc()\n\n    def set_length(self, length):\n        self.length\
      \ = int(max(1, length))\n        self.seq = self._generate_zc()\n        self.set_history(self.length)\n\
      \n    def work(self, input_items, output_items):\n        in_sig = input_items[0]\n\
      \        out_sig = output_items[0]\n        \n        # Calculate sliding correlation\n\
      \        corr = np.correlate(in_sig, self.seq, mode='valid')\n        chan_est_list\
      \ = corr / self.length\n        mags = np.abs(chan_est_list)\n\n        # We\
      \ must process samples one by one to update the state correctly\n        # if\
      \ a peak occurs mid-buffer.\n        for i in range(len(out_sig)):\n       \
      \     # If we find a new peak, update our memory\n            if mags[i] >=\
      \ self.threshold_ratio:\n                self.last_h = chan_est_list[i]\n  \
      \          \n            # Every output sample gets the 'last known good' estimate\n\
      \            out_sig[i] = self.last_h\n            \n        return len(out_sig)\n"
    affinity: ''
    alias: ''
    comment: ''
    length: '255'
    maxoutbuf: '0'
    minoutbuf: '0'
    root: '1'
    threshold_ratio: threshold
  states:
    _io_cache: ('ZC Correlator (Latched)', 'blk', [('root', '1'), ('length', '139'),
      ('threshold_ratio', '0.75')], [('0', 'complex', 1)], [('0', 'complex', 1)],
      '\n    Zadoff-Chu Correlator with Latch\n    Holds the last successful channel
      estimate (h) until a new peak is found.\n    Initializes at 1+0j.\n    ', ['length',
      'root', 'threshold_ratio'])
