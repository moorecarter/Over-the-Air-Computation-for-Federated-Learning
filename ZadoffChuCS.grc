- name: epy_block_2
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Multi-Output ZC Estimator\n    - Outputs a unique stream for\
      \ each root in the 'roots' list.\n    - Latches the last valid channel estimate\
      \ (h) until a new peak is found.\n    - Designed to be connected to 'File Sink'\
      \ or 'QT GUI Time Sink' blocks.\n    \"\"\"\n    def __init__(self, roots=[1,\
      \ 5], length=139, threshold_ratio=0.75):\n        self.roots = roots\n     \
      \   self.num_roots = len(roots)\n        \n        gr.sync_block.__init__(\n\
      \            self,\n            name='Multi-Root ZC Estimator',\n          \
      \  in_sig=[np.complex64],\n            out_sig=[np.complex64] * self.num_roots\n\
      \        )\n        \n        self.length = length\n        self.threshold_ratio\
      \ = threshold_ratio\n        \n        # Memory for latching: initialized at\
      \ 1+0j for each root\n        self.last_h_vec = [1.0 + 0.0j] * self.num_roots\n\
      \        \n        # Pre-generate sequences for each root\n        self.seq_dict\
      \ = {r: self._generate_zc(r) for r in self.roots}\n\n        # Set history to\
      \ ensure we have enough samples for the sliding correlation\n        self.set_history(self.length)\n\
      \n    def _generate_zc(self, r):\n        n = np.arange(self.length)\n     \
      \   if self.length % 2 == 0:\n            seq = np.exp(-1j * np.pi * r * (n\
      \ ** 2) / self.length)\n        else:\n            seq = np.exp(-1j * np.pi\
      \ * r * n * (n + 1) / self.length)\n        return seq.astype(np.complex64)\n\
      \n    def work(self, input_items, output_items):\n        in_sig = input_items[0]\n\
      \        n_output_samples = len(output_items[0])\n\n        # Process each output\
      \ port (one per root)\n        for idx, r in enumerate(self.roots):\n      \
      \      port_out = output_items[idx]\n            \n            # 1. Sliding\
      \ Correlation\n            # Note: with history set, 'corr' length matches 'n_output_samples'\n\
      \            corr = np.correlate(in_sig, self.seq_dict[r], mode='valid')\n \
      \           chan_est_list = corr / self.length\n            mags = np.abs(chan_est_list)\n\
      \n            # 2. Sample-by-Sample Latching\n            for i in range(n_output_samples):\n\
      \                if mags[i] >= self.threshold_ratio:\n                    #\
      \ Update the \"remembered\" channel state for this root\n                  \
      \  self.last_h_vec[idx] = chan_est_list[i]\n                \n             \
      \   # Assign the current (or latched) state to the output stream\n         \
      \       port_out[i] = self.last_h_vec[idx]\n\n        return n_output_samples\n"
    affinity: ''
    alias: ''
    comment: ''
    length: '255'
    maxoutbuf: '0'
    minoutbuf: '0'
    roots: '[1,5]'
    threshold_ratio: '0.6'
  states:
    _io_cache: ('Multi-Root ZC Estimator', 'blk', [('roots', '[1, 5]'), ('length',
      '139'), ('threshold_ratio', '0.75')], [('0', 'complex', 1)], [('0', 'complex',
      1), ('1', 'complex', 1)], "\n    Multi-Output ZC Estimator\n    - Outputs a
      unique stream for each root in the 'roots' list.\n    - Latches the last valid
      channel estimate (h) until a new peak is found.\n    - Designed to be connected
      to 'File Sink' or 'QT GUI Time Sink' blocks.\n    ", ['length', 'roots', 'threshold_ratio'])
    bus_sink: false
